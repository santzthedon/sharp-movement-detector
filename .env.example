# Copy to .env and fill in.

# "devnet" while building/testing. Switch to "mainnet" only once everything
# works, since mainnet is what carries the real World Cup free tier
# (60-second delay: service level 1, real-time: service level 12).
NETWORK=devnet

# Path to your local Solana keypair JSON (created by `npm run setup:wallet`).
WALLET_PATH=./wallet-devnet.json

# Filled in automatically by auth.ts after a successful subscribe+activate.
# You can also hardcode these here to skip re-running auth.ts every time,
# but tokens are time-limited so you will need to refresh periodically.
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=

# --- Fixture selection (get IDs from `npm run fixtures`) ---
# Completed fixtures (started 6h-2 weeks ago) for the backtest:
BACKTEST_FIXTURE_IDS=
# Live watcher: leave EMPTY for auto-discovery (attaches to every fixture
# from AUTODISCOVER_LEAD_MINUTES before kickoff until ~4.5h after, no
# manual input needed), or pin a comma-separated list of fixture IDs:
LIVE_FIXTURE_IDS=
AUTODISCOVER_LEAD_MINUTES=60

# --- Detector tuning ---
# Tuned by grid search over 103 completed World Cup 2026 fixtures
# (`npm run tune`, pre-match CLV objective): 15min window + Z_SCORE=3 gave
# 21 flags, 61.9% hit rate, +1.69pp mean CLV, 67% CLV-positive. In-sample
# tuning - treat as a sensible default, not a proven edge.
WINDOW_MINUTES=15
# Absolute floor on the flagged swing (0.02 = 2 percentage points):
PROBABILITY_THRESHOLD=0.02
# Adaptive (volatility-normalized) threshold: also require the swing to be
# >= Z_SCORE x the series' own median window range, so "big" is judged
# relative to each fixture's normal wobble. 0 disables (fixed floor only).
Z_SCORE=3
# In-play flags have no closing line; their CLV reference is the price
# this many minutes after the flag:
CLV_HORIZON_MINUTES=30
# Hours of pre-kickoff odds history the backtest pulls per fixture:
PREMATCH_HOURS=3

# --- Optional filters ---
# Which SuperOddsType values count as the match-winner market:
#ODDS_MARKET_REGEX=^1X2_PARTICIPANT_RESULT$
# Restrict fixtures listing / auto-discovery to one competition (72 = World Cup):
#COMPETITION_ID=72
#FIXTURES_LOOKBACK_DAYS=13
