# Copy to .env and fill in.

# "devnet" while building/testing. Switch to "mainnet" only once everything
# works, since mainnet is what carries the real World Cup free tier
# (60-second delay: service level 1, real-time: service level 12).
NETWORK=devnet

# Path to your local Solana keypair JSON (created by `npm run setup:wallet`).
WALLET_PATH=./wallet-devnet.json

# Filled in automatically by auth.ts after a successful subscribe+activate.
# You can also hardcode these here to skip re-running auth.ts every time,
# but tokens are time-limited so you will need to refresh periodically.
TXLINE_GUEST_JWT=
TXLINE_API_TOKEN=

# --- Fixture selection (get IDs from `npm run fixtures`) ---
# Completed fixtures (started 6h-2 weeks ago) for the backtest:
BACKTEST_FIXTURE_IDS=
# In-play / upcoming fixtures for the live watcher:
LIVE_FIXTURE_IDS=

# --- Detector tuning ---
# Calibrated against real devnet StablePrice data (2026-07-18, 9 completed
# World Cup fixtures): the demargined consensus is smooth pre-match - moves
# of 8pp/15min never occur; ~2pp/hour is where genuine signal starts.
WINDOW_MINUTES=60
PROBABILITY_THRESHOLD=0.02
# Score pre-match ticks only in the backtest (in-play odds jump on goals,
# which would trivially inflate the hit rate):
PREMATCH_ONLY=true
# Hours of pre-kickoff odds history to pull per fixture:
PREMATCH_HOURS=3

# --- Optional filters ---
# Which SuperOddsType values count as the match-winner market. The client
# logs every market label it sees on first fetch - tighten this after that.
#ODDS_MARKET_REGEX=1x2
# Restrict `npm run fixtures` to one competition:
#COMPETITION_ID=72
#FIXTURES_LOOKBACK_DAYS=13
